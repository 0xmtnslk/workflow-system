# Project
PROJECT_NAME=gws-system

# Database (PostgreSQL)
POSTGRES_USER=gws_user
POSTGRES_PASSWORD=gws_password
POSTGRES_DB=gws_db
POSTGRES_PORT=5432
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Backend
BACKEND_PORT=3001
JWT_SECRET=super-secret-key-change-me-in-production

# Frontend
FRONTEND_PORT=3000

# SMTP (Initial place holders)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM_NAME="GWS System"
SMTP_FROM_EMAIL=no-reply@example.com
